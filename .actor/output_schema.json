{
	"$schema": "https://apify.com/schemas/v1/output.ide.json",
	"actorOutputSchemaVersion": 1,
	"title": "TripAdvisor Reviews Scraper Output",
	"properties": {
		"dataset": {
			"type": "string",
			"title": "Reviews",
			"description": "Reviews in the default dataset",
			"template": "{{links.apiDefaultDatasetUrl}}/items"
		},
		"keyValueStore": {
			"type": "string",
			"title": "Places",
			"description": "Place metadata (reviewCount, oldestDate, error) in key-value store",
			"template": "{{links.apiDefaultKeyValueStoreUrl}}/keys"
		}
	}
}
